<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">
    <EditText android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Introdueix un número" android:inputType="number" />
    <Button android:id="@+id/btnLoad" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="MOSTRAR 100 POSTS" />
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvPosts" android:layout_width="match_parent" android:layout_height="match_parent" />
</LinearLayout>